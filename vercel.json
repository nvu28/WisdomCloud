{
  "services": {
    "frontend": {
      "root": "frontend",
      "buildCommand": "npm install && npm run build",
      "outputDirectory": "dist"
    }
  },
  "rewrites": [
    { "source": "/_/backend/api/v1/(.*)", "destination": "/api/search" },
    { "source": "/api/v1/(.*)", "destination": "/api/search" }
  ]
}
